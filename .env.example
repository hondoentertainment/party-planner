# Copy this file to `.env.local` and fill in your Supabase project values.
# Find them in Supabase → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — only for `npm run db:types` (Reference ID in Project Settings → General)
# SUPABASE_PROJECT_ID=

# Optional — Sentry (browser DSN; leave empty to disable)
# VITE_SENTRY_DSN=

# Optional — Web push (VAPID public key only; generate with `npx web-push generate-vapid-keys`)
# Must match the public key configured on the notify-assignment Edge Function.
# VITE_VAPID_PUBLIC_KEY=

# Optional — Playwright (npm run test:e2e / verify). Same user must exist in Supabase Auth.
# Merged from .env.local by playwright.config.ts; CI uses GitHub Actions secrets only.
# E2E_EMAIL=
# E2E_PASSWORD=

# Optional — Playwright preview port (default 4291) and reuse. See playwright.config.ts.
# PW_PREVIEW_PORT=4291
# PW_REUSE_DEV_SERVER=1
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4291
