# Copy this file to `.env.local` and fill in your Supabase project values.
# Find them in Supabase → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — Sentry (browser DSN; leave empty to disable)
# VITE_SENTRY_DSN=

# Optional — Web push (VAPID public key only; generate with `npx web-push generate-vapid-keys`)
# Must match the public key configured on the notify-assignment Edge Function.
# VITE_VAPID_PUBLIC_KEY=
